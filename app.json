{
  "expo": {
    "name": "Life Countdown",
    "slug": "life-countdown",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "lifecountdown",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.evcengage.lifecountdown",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.evcengage.lifecountdown",
      "versionCode": 1
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ff6b35"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b3fb4aad-4ae0-4d35-a689-bb92f99ac962"
      }
    },
    "owner": "mj1133"
  }
}
